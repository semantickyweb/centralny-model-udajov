    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Approximate Group Framework Agreement Value</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the estimated Monetary Value of the Lot Group within the Framework Agreement.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBankingIdentifier">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#PaymentInstructionsInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#inv" />
    <skos:prefLabel xml:lang="en">has Banking Identifier</skos:prefLabel>
    <skos:definition xml:lang="en">An unique banking reference identifier of the Payee or Seller, assigned by the Payee or Seller bank.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 11/07/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLoadingMeter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Consignment" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Loading Meter</skos:prefLabel>
    <skos:definition xml:lang="en">The area of the Consignment in meters divided by the width of the truck, which is considered to be 2.4 meters.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 18/06/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMandateIdentifier">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#PaymentInstructionsInformation" />
