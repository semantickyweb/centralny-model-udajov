    <skos:prefLabel xml:lang="en">is Refrigerated</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates whether the instance of the concept includes refrigeration. Additional Information: The instance of the concept can be, for example, Transport Equipment. (epo-ful:TransportEquipment)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 05/06/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isRelatedToItem">
