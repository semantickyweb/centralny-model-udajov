    <skos:prefLabel xml:lang="en">Transport Handling Unit</skos:prefLabel>
    <skos:definition xml:lang="en">The outermost Package that the Carrier is handling.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 14/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TransportMeans">
