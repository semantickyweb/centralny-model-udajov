    <rdfs:range rdf:nodeID="b207541359" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#PostAwardCatalogue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
