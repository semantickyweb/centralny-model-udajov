    <rdfs:subClassOf rdf:nodeID="b207541711" />
    <rdfs:subClassOf rdf:nodeID="b207541322" />
    <rdfs:subClassOf rdf:nodeID="b207541200" />
    <rdfs:subClassOf rdf:nodeID="b207540625" />
    <skos:prefLabel xml:lang="en">Delivery Agreement</skos:prefLabel>
    <skos:definition xml:lang="en">Term applying to the delivery of goods, services and works. Additional Information: Delivery terms identifier can normally be Incoterms accompanied by the description of specific conditions related to the delivery.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 16/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#DeliveryInformation">
