    <rdfs:subClassOf rdf:nodeID="b207541419" />
    <skos:prefLabel xml:lang="en">Contract Information</skos:prefLabel>
    <skos:definition xml:lang="en">Information about the Contract.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 20/04/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#ContractModificationInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
