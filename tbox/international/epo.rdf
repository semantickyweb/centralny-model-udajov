    <rdfs:subClassOf rdf:nodeID="b207541129" />
    <rdfs:subClassOf rdf:nodeID="b207541130" />
    <rdfs:subClassOf rdf:nodeID="b207541131" />
    <skos:prefLabel xml:lang="en">Shipment Stage</skos:prefLabel>
    <skos:definition xml:lang="en">Part of the itinerary of a shipment. Additional information: In the context of fulfilment only the last part of the itinerary is taken into consideration.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2024</skos:historyNote>
  </rdf:Description>
