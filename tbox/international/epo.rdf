    <skos:historyNote xml:lang="en">WG Approval 05/03/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#providesOrganisationCompletedTaskDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#OrganisationInformationSummary" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#sub" />
    <skos:prefLabel xml:lang="en">provides Organisation Completed Task Description</skos:prefLabel>
    <skos:definition xml:lang="en">Text describing the works, supplies or services executed, delivered or performed in a procurement project that can be used as an evidence for the classification of the Organization. (epo-sub:OrganisationInformationSummary)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 05/03/2024</skos:historyNote>
  </rdf:Description>
