    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#inv" />
    <skos:prefLabel xml:lang="en">has Mandate Identifier</skos:prefLabel>
    <skos:definition xml:lang="en">An unique identifier for referencing the direct debit mandate, assigned by the Payee.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 11/07/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasPreferredLanguageForProcurementDocument">
