    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Publication Date</skos:prefLabel>
    <skos:definition xml:lang="en">Date of formal public issuance of the document. (epo:Document)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 20/06/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasPurpose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207540328" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Purpose" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Purpose</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Purpose of a concept.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasQualifiedValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ItemProperty" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Qualified Value</skos:prefLabel>
    <skos:definition xml:lang="en">Qualified value of the property, which is defined in a classification scheme. Additional Information: For example, the (0173-1#02-AAA026#007) drilling diameter of an item has value of 12 inches.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 28/07/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasQuantityThreshold">
