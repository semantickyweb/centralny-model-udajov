  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#Candidate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#OfferingParty" />
    <skos:prefLabel xml:lang="en">Candidate</skos:prefLabel>
    <skos:definition xml:lang="en">The Role of an Agent that has sought an invitation or has been invited to take part in a restricted Procedure, in a competitive Procedure with negotiation, in a negotiated Procedure without prior publication, in a competitive dialogue or in an innovation partnership.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 30/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#Carrier">
