    <skos:definition xml:lang="en">The procurement falls within the scope of the European Parliament and Council 2009/33/EC (Clean Vehicles Directive – CVD). (epo:GreenProcurement)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#specifiesProcurementCriterion">
