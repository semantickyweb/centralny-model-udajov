    <skos:prefLabel xml:lang="en">Contract Modification Information</skos:prefLabel>
    <skos:definition xml:lang="en">Information about a Contract Amendment.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 11/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#Deliverable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#con" />
