    <rdfs:subClassOf rdf:nodeID="b207541196" />
    <rdfs:subClassOf rdf:nodeID="b207541194" />
    <rdfs:subClassOf rdf:nodeID="b207541195" />
    <rdfs:subClassOf rdf:nodeID="b207540381" />
    <skos:prefLabel xml:lang="en">Deliverable</skos:prefLabel>
    <skos:definition xml:lang="en">Item that the supplier is obligated to provide under a contract.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 11/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#DeliveryAgreement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ord" />
