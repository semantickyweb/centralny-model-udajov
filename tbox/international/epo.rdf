    <rdfs:subClassOf rdf:nodeID="b207540587" />
    <rdfs:subClassOf rdf:nodeID="b207540852" />
    <skos:prefLabel xml:lang="en">Transport Equipment Seal</skos:prefLabel>
    <skos:definition xml:lang="en">Means used to ensure that the Transport Equipment is not tampered during transportation.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TransportHandlingUnit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
