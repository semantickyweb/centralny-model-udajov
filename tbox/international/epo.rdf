    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Address URL</skos:prefLabel>
    <skos:definition xml:lang="en">The resource identifier for a Channel. (cv:Channel)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 26/03/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAllowanceChargeReason">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
