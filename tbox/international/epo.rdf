    <rdfs:subClassOf rdf:nodeID="b207541086" />
    <rdfs:subClassOf rdf:nodeID="b207541087" />
    <skos:prefLabel xml:lang="en">Transport Equipment</skos:prefLabel>
    <skos:definition xml:lang="en">Description of the apparatus used during transportation. Additional information: The equipment may be a container, a trailer, means of assistance to load or unload the Goods Items.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TransportEquipmentSeal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
