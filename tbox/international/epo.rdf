    <skos:prefLabel xml:lang="en">provides Evidence</skos:prefLabel>
    <skos:definition xml:lang="en">Makes available the Evidence.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#specifiesReceiptAdviceInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ReceiptAdvice" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#ReceiptAdviceInformation" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
    <skos:prefLabel xml:lang="en">specifies Receipt Advice Information</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Receipt Advice Information.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#Asset">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:subClassOf rdf:nodeID="b207541772" />
    <rdfs:subClassOf rdf:nodeID="b207541773" />
    <rdfs:subClassOf rdf:nodeID="b207541774" />
    <skos:prefLabel xml:lang="en">Asset</skos:prefLabel>
    <skos:definition xml:lang="en">Resource necessary for the provision of a service.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#QualityTargetInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#ContextDescription" />
    <rdfs:subClassOf rdf:nodeID="b207541092" />
    <rdfs:subClassOf rdf:nodeID="b207541093" />
    <skos:prefLabel xml:lang="en">Quality Target Information</skos:prefLabel>
    <skos:definition xml:lang="en">Information about a specific performance goal.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 23/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCompensationCostParametersDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Compensation Cost Parameters Description</skos:prefLabel>
    <skos:definition xml:lang="en">Explanatory text about the parameters of the financial compensation. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDurationAdditionalInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Duration Additional Information</skos:prefLabel>
    <skos:definition xml:lang="en">Supplementary data about the Duration of the Contract. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 07/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasGrantedExclusiveRightsDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Granted Exclusive Rights Description</skos:prefLabel>
    <skos:definition xml:lang="en">Explanatory text about the applicable right entitling a public service operator to operate certain public passenger transport services on a particular route or network or in a particular area, to the exclusion of any other such operator. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasPredominance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Asset" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Predominance</skos:prefLabel>
    <skos:definition xml:lang="en">Estimated percentage-share of Assets provided compared to Assets used for activities other than the public services. (epo:Asset)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasPublicServiceObligationsDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Public Service Obligations Description</skos:prefLabel>
    <skos:definition xml:lang="en">Explanatory text about the requirement defined or determined by a competent authority in order to ensure public passenger transport services in the general interest that an operator, if it were considering its own commercial interests, would not assume or would not assume to the same extent or under the same conditions without reward. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasReservedExecutionJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Reserved Execution Justification</skos:prefLabel>
    <skos:definition xml:lang="en">An explanation about why the Contract must be performed in the framework of sheltered employment programmes. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 23/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasSocialStandardsDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Social Standards Description</skos:prefLabel>
    <skos:definition xml:lang="en">Explanatory text about the standards required, including staff concerned, detail of their contractual rights and obligations and conditions under which employees are considered to be linked to the services. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
