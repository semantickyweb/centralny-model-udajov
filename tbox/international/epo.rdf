    <skos:prefLabel xml:lang="en">Notice T02</skos:prefLabel>
    <skos:definition xml:lang="en">Result notice for public passenger transport services by rail and by road.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#NotificationReceiver">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
