  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAbnormallyLowTenders">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Abnormally Low Tenders</skos:prefLabel>
    <skos:definition xml:lang="en">Tenders received that were found irregular and non-acceptable due to an abnormally low price or cost. Additional Information The definition implies that abnormally Low Tender Lots are Inadmissible Tender Lots. (epo:SubmissionStatisticalInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 28/07/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAcceleratedProcedureJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Procedure" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Accelerated Procedure Justification</skos:prefLabel>
    <skos:definition xml:lang="en">The reasons why the procedure is accelerated. Additional Information: A procedure is accelerated to cover needs of extraordinary circumstances ie earthquake relief. (epo:Procedure)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/06/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAccessURL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DeliveryInformation" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Document" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ord" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Access URL</skos:prefLabel>
    <skos:definition xml:lang="en">Location where the resource can be accessed. (epo-ord:DeliveryInformation)</skos:definition>
    <skos:definition xml:lang="en">Location where the resource can be accessed. (epo:Document)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 07/04/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAccessibilityDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#NonPublishedInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Accessibility Date</skos:prefLabel>
    <skos:definition xml:lang="en">The date at which unpublished data shall be published. (epo:NonPublishedInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 11/06/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasActivityDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Buyer" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Activity Description</skos:prefLabel>
    <skos:definition xml:lang="en">In the ePO ontology a taxonomy with all activities, based on different classifications (COFOG, UTILITIES, NACE), will be provided. In ePO this field is to be used exclusively to complement the definition attached to the MainActivityCode. However, in eForms there is the code &quot;other&quot; to cover undefined activities. For mapping to this eForms feature one could also use this property. (epo:Buyer)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAdditionalClassification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Purpose" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Additional Classification</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the additional Common Procurement Vocabulary code.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAdditionalContractNature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Additional Contract Nature</skos:prefLabel>
    <skos:definition xml:lang="en">Additional type of acquisition taken into consideration in the contract.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAdditionalInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Line" />
    <rdfs:domain rdf:nodeID="b207541987" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Additional Information</skos:prefLabel>
    <skos:definition xml:lang="en">Supplementary data about the instance of the concept. (epo:ProcurementElement) Supplementary data about the instance of the concept. (epo:ProcurementCriterion) Supplementary data about the instance of the concept. (epo:Document) Supplementary data about the instance of the concept. (epo:ChangeInformation)</skos:definition>
    <skos:definition xml:lang="en">Supplementary data about the instance of the concept. (epo-cat:Line)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eforms BT-300</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 15/10/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAdditionalInformationDeadline">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AccessTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Additional Information Deadline</skos:prefLabel>
    <skos:definition xml:lang="en">The time limit for requesting further information. Additional information: This is generally used to indicate the deadline for Economic Operators to request further information of the procedure before the submission deadline. (epo:AccessTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-13</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 09/06/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAlias">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Alias</skos:prefLabel>
    <skos:definition xml:lang="en">Acronym or alternative name of the Agent. (foaf:Agent)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 25/03/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAllegedIrregularityType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ReviewRequest" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Alleged Irregularity Type</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the presumed Irregularity Type.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAmountValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Amount Value</skos:prefLabel>
    <skos:definition xml:lang="en">The numeric value of the amount, including decimals. (epo:MonetaryValue)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardCriteriaEvaluationFormula">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardEvaluationTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Award Criteria Evaluation Formula</skos:prefLabel>
    <skos:definition xml:lang="en">The mathematical equation or any other description used for complicated weighing of criteria (e.g. non-linear weighing, the analytic hierarchy process) when a weighing cannot be expressed per criterion. (epo:AwardEvaluationTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-543</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardCriteriaOrderJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardEvaluationTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Award Criteria Order Justification</skos:prefLabel>
    <skos:definition xml:lang="en">The justification for only indicating the award criteria&#39;s order of importance, not their weighing. (epo:AwardEvaluationTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-733</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardCriterionType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardCriterion" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Award Criterion Type</skos:prefLabel>
    <skos:definition xml:lang="en">Category of award criterion.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardDateScheduled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcessPlanningTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Award Date Scheduled</skos:prefLabel>
    <skos:definition xml:lang="en">Planned date for the award decision. (epo:ProcessPlanningTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardDecisionDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardDecision" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Award Decision Date</skos:prefLabel>
    <skos:definition xml:lang="en">The official date of the award decision. (epo:AwardDecision)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-1451</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 09/01/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardRank">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#TenderAwardOutcome" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Award Rank</skos:prefLabel>
    <skos:definition xml:lang="en">The position of the tender (i.e. whether the tender ended up first, second, third, etc.) in a design contest, some framework agreements with multiple winners (e.g. cascades) or an innovation partnership. (epo:TenderAwardOutcome)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-171</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardOutcome" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Award Status</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates whether the lot is awarded, not awarded or still open.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardedValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardOutcome" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Awarded Value</skos:prefLabel>
    <skos:definition xml:lang="en">The value of the procurement provided by the Award Decision. Additional Information: Different cases of awarded values may refer to a lot, the global value of the procedure, or of a combinatorial value of a group of lots. In the case of framework agreements and dynamic purchasing systems this refers to the maximum awarded value.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 10/12/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBaseQuantity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Price" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Base Quantity</skos:prefLabel>
    <skos:definition xml:lang="en">The quantity at which the net monetary value applies.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBeneficialOwner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <owl:inverseOf rdf:resource="http://data.europa.eu/a4g/ontology#isBeneficialOwnerOf" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Business" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/person#Person" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Beneficial Owner</skos:prefLabel>
    <skos:definition xml:lang="en">A role of any natural person(s) who ultimately owns or controls the organisation or on whose behalf a transaction or activity is being conducted. Additional Information: This role is defined in the directive EU 2015/849 and it&#39;s beyond the scope for public eProcurement domain.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 14/09/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBroadPlaceOfPerformance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Broad Place Of Performance</skos:prefLabel>
    <skos:definition xml:lang="en">Geopolitical zone where the contract can be executed. Additional Information Used for setting restrictions that cannot be established with one country code or a geographical zone identifier (like NUTS), because they have a broader scope (geographical, economic, political, other).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBusinessSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Business" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Business Size</skos:prefLabel>
    <skos:definition xml:lang="en">The category of the business depending on number of employees and turnover. Additional information: See Commission Recommendation of 6 May 2003 concerning the definition of micro, small and medium-sized enterprises.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBuyerCategoryDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#FrameworkAgreementTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Buyer Category Description</skos:prefLabel>
    <skos:definition xml:lang="en">A classification of buyers participating in a framework agreement. Additional Information: Buyers that can use the Framework Agreement not mentioned by name. For example, the classification &quot;all hospitals in the Tuscany region&quot; is used instead of naming each individual buyer. (epo:FrameworkAgreementTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-111</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 06/05/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBuyerProfile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Buyer" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Buyer Profile</skos:prefLabel>
    <skos:definition xml:lang="en">Website address where the buyer publishes information on its procurement procedures and general information. (epo:Buyer)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-508</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG approval 04/05/2018</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCalculationMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#EnvironmentalEmissionInformation" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ConcessionEstimate" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Calculation Method</skos:prefLabel>
    <skos:definition xml:lang="en">Formula for obtaining values. Additional Information: The possible values are monetary values, ranking scores, criterion weighting. (epo-cat:EnvironmentalEmissionInformation)</skos:definition>
    <skos:definition xml:lang="en">Formula for obtaining values. Additional Information: The possible values are monetary values, ranking scores, criterion weighting. (epo:ConcessionEstimate)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 25/05/2018</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCatalogueLineValidity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#CatalogueLine" />
    <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Catalogue Line Validity</skos:prefLabel>
    <skos:definition xml:lang="en">The relation indicating until when a Catalogue Line instance is applicable.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/09/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasChangeDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ChangeInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Change Description</skos:prefLabel>
    <skos:definition xml:lang="en">Explanatory text about the instance of the concept. (epo:ChangeInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 30/09/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasChangeJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ChangeInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Change Justification</skos:prefLabel>
    <skos:definition xml:lang="en">Code explaining the change.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasChangeReasonDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ChangeInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Change Reason Description</skos:prefLabel>
    <skos:definition xml:lang="en">Explanatory text about why the element is altered. (epo:ChangeInformation)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-762</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCleanVehicles">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#CleanVehicleDirectiveInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Clean Vehicles</skos:prefLabel>
    <skos:definition xml:lang="en">The number of all clean vehicles that have either been purchased, leased, rented, hired-purchased or their use has been contractually committed to for the provision of a purchased service. Additional Information: In the European Union, the legal requirements and scope for the provision of these vehicles or services are covered by Directive 2009/33/EC. (epo:CleanVehicleDirectiveInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 28/07/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasConfidentialityJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#NonPublishedInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Confidentiality Justification</skos:prefLabel>
    <skos:definition xml:lang="en">A narrative explanation of why data is not published. Additional Information: This element is generally used when the non-publication-justification code chosen is &quot;other&quot;. (epo:NonPublishedInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasConfirmedIrregularityType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ReviewDecision" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Confirmed Irregularity Type</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the confirmed Irregularity Type.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207540496" />
    <rdfs:range rdf:resource="http://data.europa.eu/m8g/Constraint" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Constraint</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating that the instance of the concept has a Constraint.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasContactName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/m8g/ContactPoint" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Contact Name</skos:prefLabel>
    <skos:definition xml:lang="en">A short text by which a contact is known or referred to. (cpov:ContactPoint)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval: 27/01/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasContactPointInRole">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AgentInRole" />
    <rdfs:range rdf:resource="http://data.europa.eu/m8g/ContactPoint" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Contact Point In Role</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Agent In Role has a Contact Point.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasContractConclusionDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Contract" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Contract Conclusion Date</skos:prefLabel>
    <skos:definition xml:lang="en">The date the contract was signed by the last signatory party. &lt;u&gt;Additional Information:&lt;/u&gt; In exceptional cases contracts may be concluded without signature and therefore another date may be used. The date of contract conclusion is always later than the end of any standstill period. This concept is not to be confused with the date of completion/end of the contract. (epo:Contract)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-145</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 09/01/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasContractNatureType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Contract Nature Type</skos:prefLabel>
    <skos:definition xml:lang="en">Subject of the acquisition.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCountryCode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207540554" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Country Code</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Country code.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCountryOfBirth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/person#Person" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Country Of Birth</skos:prefLabel>
    <skos:definition xml:lang="en">The country in which the Person was born.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCountryOfOrigin">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AbstractItem" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Country Of Origin</skos:prefLabel>
    <skos:definition xml:lang="en">The source country of the product or service. Additional Information: The country of origin can be provided by the buyer as a requirement or by the tenderer information of the item to be provided.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCrossBorderLaw">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Cross Border Law</skos:prefLabel>
    <skos:definition xml:lang="en">The applicable law when buyers from different countries procure together within one procurement procedure. (epo:ProcedureTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-09</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCurrencyCodeListAgencyID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Currency Code List Agency ID</skos:prefLabel>
    <skos:definition xml:lang="en">Identifier of the agency that maintains the currency code list used. (epo:MonetaryValue)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 13/04/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCurrencyCodeListAgencyName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Currency Code List Agency Name</skos:prefLabel>
    <skos:definition xml:lang="en">Name of the agency that maintains the currency code list used. (epo:MonetaryValue)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 13/04/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCurrencyCodeListID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Currency Code List ID</skos:prefLabel>
    <skos:definition xml:lang="en">Concept scheme URI used for the currency code list. (epo:MonetaryValue)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 13/04/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDPSScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DynamicPurchaseSystemTechnique" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has DPS Scope</skos:prefLabel>
    <skos:definition xml:lang="en">Explanation as to whether a dps is used and by whom. The codelist to be used is at-voc:dps-usage which is available at http://publications.europa.eu/resource/dataset/dps-usage</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDeadline">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SecurityClearanceTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Deadline</skos:prefLabel>
    <skos:definition xml:lang="en">The time limit by which the security clearance must be submitted to the buyer. (epo:SecurityClearanceTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 02/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDeliveryLocation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Price" />
    <rdfs:range rdf:resource="http://purl.org/dc/terms/Location" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Delivery Location</skos:prefLabel>
    <skos:definition xml:lang="en">Location delivery area where the Item can be ordered to the given price.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDirectAwardJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DirectAwardTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Direct Award Justification</skos:prefLabel>
    <skos:definition xml:lang="en">List of reasons for using a procedure which allows awarding contracts directly without publishing a notice.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDispatchDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Document" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Dispatch Date</skos:prefLabel>
    <skos:definition xml:lang="en">Date and time of transmission of a record to an Organization. (epo:Document)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 31/08/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDocumentRestrictionJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AccessTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Document Restriction Justification</skos:prefLabel>
    <skos:definition xml:lang="en">An explanation about the reasons why some procurement documents are restricted.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDurationExtensionJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#FrameworkAgreementTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Duration Extension Justification</skos:prefLabel>
    <skos:definition xml:lang="en">The explanation of the reason why the framework agreement has an extended duration. Additional Information: The justification for exceptional cases when the duration of the framework agreement exceeds the legal limits. Four years in the case of the general procurement Directive, seven years in the case of the defence Directive, and eight years in the case of the sectoral Directive. (epo:FrameworkAgreementTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-109</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 26/09/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEAuctionURL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has E Auction URL</skos:prefLabel>
    <skos:definition xml:lang="en">The internet address of the electronic auction. (epo:SubmissionTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-123</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasECataloguePermission">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has E Catalogue Permission</skos:prefLabel>
    <skos:definition xml:lang="en">The extent to which electronic catalogues may be used in tenders.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEEAReceivedTenders">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has EEA Received Tenders</skos:prefLabel>
    <skos:definition xml:lang="en">The amount of tenders received from economic operators in other EEA countries other than the country of the buyer. (epo:SubmissionStatisticalInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/12/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEInvoicing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has E Invoicing</skos:prefLabel>
    <skos:definition xml:lang="en">Electronic means will be used for invoicing in the post-award process. Additional Information: This attribute is used for standard form mappings. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/09/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEOrdering">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has E Ordering</skos:prefLabel>
    <skos:definition xml:lang="en">Electronic means will be used for requesting and purchasing in the post-award process. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/09/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEPayment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has E Payment</skos:prefLabel>
    <skos:definition xml:lang="en">Electronic means must be used for paying. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasESubmissionPermission">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has E Submission Permission</skos:prefLabel>
    <skos:definition xml:lang="en">The requirements as to what extent electronic submission is allowed.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEUReceivedTenders">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has EU Received Tenders</skos:prefLabel>
    <skos:definition xml:lang="en">The amount of tenders received from economic operators in other EU countries other than the country of the buyer. (epo:SubmissionStatisticalInformation)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasElectronicSubmission">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Tender" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Electronic Submission</skos:prefLabel>
    <skos:definition xml:lang="en">Transmission of tenders is possible by electronic means of communication. (epo:Tender)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasElectronicTenders">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Electronic Tenders</skos:prefLabel>
    <skos:definition xml:lang="en">Electronic Tender Lots received. (epo:SubmissionStatisticalInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 28/07/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasElementReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ReviewInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Element Reference</skos:prefLabel>
    <skos:definition xml:lang="en">Reference to the class instance in the current notice. (epo:ReviewInformation)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-13716, eForms BT-786, eForms BT-1501</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEntryIntoForceDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Contract" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Entry Into Force Date</skos:prefLabel>
    <skos:definition xml:lang="en">The date on which the contract enters into force. Additional information: This is generally the date on which the fulfillment of the contract begins. (epo:Contract)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 05/11/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedBuyerConcessionRevenue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ConcessionEstimate" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Buyer Concession Revenue</skos:prefLabel>
    <skos:definition xml:lang="en">The expected payments made by the buyer to the economic operator awarded the concession that are not directly related to the use of the concession. &lt;u&gt;Additional Information:&lt;/u&gt; For example the public buyer pays a yearly fee to provide a ticketing solution to the public. The fee the public pays for every ticket sold through the solution is not included in this estimation but in the estimation of the user concession revenue.</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-160</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 07/01/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedContractNoticePublicationDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcessPlanningTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Contract Notice Publication Date</skos:prefLabel>
    <skos:definition xml:lang="en">Foreseen date for publication of Contract Notice. (epo:ProcessPlanningTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-127</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedDuration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DynamicPurchaseSystemTechnique" />
    <rdfs:range rdf:resource="http://www.w3.org/2006/time#Duration" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Duration</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating a Dynamic Purchase System has an estimated Duration.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 28/11/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedInvitationToExpressInterestDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MultipleStageProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Invitation To Express Interest Date</skos:prefLabel>
    <skos:definition xml:lang="en">The estimated date of dispatch of the invitations to confirm interest. (epo:MultipleStageProcedureTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-631</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedInvitationToTenderDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MultipleStageProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Invitation To Tender Date</skos:prefLabel>
    <skos:definition xml:lang="en">The estimated date of dispatch of the invitations to submit tenders in two (or more) stage procedures. (epo:MultipleStageProcedureTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-130</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 01/10/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedPercentage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubcontractingEstimate" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Percentage</skos:prefLabel>
    <skos:definition xml:lang="en">The estimated proportion foreseen to be subcontracted. (epo:SubcontractingEstimate)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 07/01/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedTenderInvitationDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcessPlanningTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Tender Invitation Date</skos:prefLabel>
    <skos:definition xml:lang="en">The planned date for the dispatch of the invitations to submit tenders. (epo:ProcessPlanningTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedTotalSubcontracts">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Total Subcontracts</skos:prefLabel>
    <skos:definition xml:lang="en">The estimated amount of work to be subcontracted in the contract resulting from the lot. (epo:SubmissionStatisticalInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedUserConcessionRevenue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ConcessionEstimate" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated User Concession Revenue</skos:prefLabel>
    <skos:definition xml:lang="en">The estimated revenue coming from the use of the concession. Additional Information: Revenues are for example fees and fines. For example, the fees and fines coming from the cars using a motorway.</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-162</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEstimatedValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207540806" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Estimated Value</skos:prefLabel>
    <skos:definition xml:lang="en">A forecast of the value of the procurement before competition. Additional Information: Different cases of estimated values may refer to a lot, the global value of the procedure, or of a combinatorial value of a group of lots. The forecast is calculated by the buyer and covers all revenues whether coming from the buyer or third parties. See for example recital (19), Article 5 of Directive 2014/24/EU and other articles from the rest of Directives about procurement. In the case of framework agreements and dynamic purchasing systems this refers to the maximum estimated value.</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-27,eForms BT-157</skos:editorialNote>
    <skos:editorialNote xml:lang="en">Used by eForms BT-27, can be used for BT-157</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 05/12/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasExpectedDeliveryTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Price" />
    <rdfs:range rdf:resource="http://www.w3.org/2006/time#Duration" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Expected Delivery Time</skos:prefLabel>
    <skos:definition xml:lang="en">The expected amount of time between the order and delivery of an item.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 26/07/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFax">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/m8g/ContactPoint" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Fax</skos:prefLabel>
    <skos:definition xml:lang="en">The fax number used to reach a person or an organisation. (cpov:ContactPoint)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFinancialOfferValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Tender" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Financial Offer Value</skos:prefLabel>
    <skos:definition xml:lang="en">The value offered by the Tenderer for a Lot. Additional Information: This value is normally the one awarded for a winning Tender Lot. In case of negotiated procedures the original financial value may be reviewed and the offer updated.</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-720</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFixedValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardCriterion" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Fixed Value</skos:prefLabel>
    <skos:definition xml:lang="en">Constant number. (epo:AwardCriterion)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-541, eForms BT-5422</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG approval 09/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFixedValueType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardCriterion" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Fixed Value Type</skos:prefLabel>
    <skos:definition xml:lang="en">The method to interpret the fixed value as pertaining to a total or unit.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFollowupContract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DesignContestRegimeTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Followup Contract</skos:prefLabel>
    <skos:definition xml:lang="en">Any subsequent service contract will be awarded to the winner or, in the case of a design contest, winners. (epo:DesignContestRegimeTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 29/08/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFollowupContractInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DesignContestRegimeTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Followup Contract Information</skos:prefLabel>
    <skos:definition xml:lang="en">Further information about follow-up contracts, prizes and payments (for example non-monetary prizes, payments given for participation). (epo:DesignContestRegimeTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 03/09/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFormType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Notice" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <skos:prefLabel xml:lang="en">has Form Type</skos:prefLabel>
    <skos:definition xml:lang="en">A categorisation of the steps in which the Notice is used.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFormula">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcurementCriterion" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Formula</skos:prefLabel>
    <skos:definition xml:lang="en">The mathematical equation or any other description used for complicated weighing of criteria (e.g. non-linear weighing, the analytic hierarchy process) when a weighing cannot be expressed per criterion. (epo:ProcurementCriterion)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-543</skos:editorialNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFrameworkAgreementMaximumValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#LotAwardOutcome" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Framework Agreement Maximum Value</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the maximum Monetary Value of the Framework Agreement.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFrameworkAgreementType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#FrameworkAgreementTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Framework Agreement Type</skos:prefLabel>
    <skos:definition xml:lang="en">The form of framework agreement used in a procurement procedure. Addition information: A concept to distinguish the different types of framework agreement, which are: 1. Framework agreement without reopening of competition, 2. Framework agreement with reopening of competition, or 3. Framework agreement partly without reopening of competition.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasGroupLotEvaluationMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Group Lot Evaluation Method</skos:prefLabel>
    <skos:definition xml:lang="en">Description of how lots and groups of lots are evaluated against one another in the procedure. (epo:ProcedureTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasGroupType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#OrganisationGroup" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Group Type</skos:prefLabel>
    <skos:definition xml:lang="en">Form of collaboration agreement between organisations. Additional Information: This is not a legal type; not to be mistaken with epo:hasLegalFormType which may also be used for Organisation Groups. (epo:OrganisationGroup)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasGuaranteeDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Guarantee Description</skos:prefLabel>
    <skos:definition xml:lang="en">Information on the financial commitment required from the economic operator. Additional Information: 1. This information may include the amount and the way of delivering of the guarantee 2. The financial commitment may be retained by the buyer in the case the tenderer withdraws the submitted information (i.e. tender, expression of interest and request for participation, but not request for clarifications) before the award of the contract or does not sign the contract. 3. Usual modalities are bonds, cheques, loans, other. (epo:SubmissionTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/07/20</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasHighestReceivedTenderValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Highest Received Tender Value</skos:prefLabel>
    <skos:definition xml:lang="en">Amount of the Tender with the highest value. Additional Information The value must correspond to an admissible tender. For example, tenders compliant with the procurement document requirements, not having an abnormally low price or cost, etc.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/12/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasImplementingRegulation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <skos:prefLabel xml:lang="en">has Implementing Regulation</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates under which Implementing Regulation a Notice is created. Additional information: This concept is same as epo:isBasedOnImplementingRegulation and will be deprecated in a future version. It is recommended to use epo:isBasedOnImplementingRegulation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasInadmissibleTenders">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Inadmissible Tenders</skos:prefLabel>
    <skos:definition xml:lang="en">Tenders received that cannot be awarded due to non-compliance to procurement document requirements or having an abnormally low price or cost. &lt;u&gt;Additional Information: &lt;/u&gt; Non-compliance with a Procurement Document requirements include exclusion grounds, selection criteria and submission deadline, etc. (epo:SubmissionStatisticalInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/12/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasInternetAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:nodeID="b207540660" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Internet Address</skos:prefLabel>
    <skos:definition xml:lang="en">The main web page used by the instance of the concept. (org:Organization) The main web page used by the instance of the concept. (cpov:ContactPoint)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 01/06/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasIrregularityType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ReviewIrregularitySummary" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Irregularity Type</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Irregularity Type.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasItemCountryOfOrigin">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Tender" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Item Country Of Origin</skos:prefLabel>
    <skos:definition xml:lang="en">The source country of the product or service. Additional Information: The country of origin can be provided by the buyer as a requirement or by the tenderer information of the item to be provided. The codelist to be used is at-voc:country which is available at http://publications.europa.eu/resource/dataset/country</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasItemStandardID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AbstractItem" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Item Standard ID</skos:prefLabel>
    <skos:definition xml:lang="en">The general identifier assigned to the concept based on a standard scheme.​ Additional information: For example the GTIN scheme (Global Trade Item Number).</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 16/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DirectAwardTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Justification</skos:prefLabel>
    <skos:definition xml:lang="en">An explanation about the reasons for using the concept. (epo:DirectAwardTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 05/11/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLanguage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Language</skos:prefLabel>
    <skos:definition xml:lang="en">Language in which the submitted information is to be expressed.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLateSubmissionInformationDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Late Submission Information Description</skos:prefLabel>
    <skos:definition xml:lang="en">A narrative text explaining the content of the economic operator information that can be submitted late. Additional Information This does not apply to requests for clarifications. (epo:SubmissionTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLateSubmissionPermission">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Late Submission Permission</skos:prefLabel>
    <skos:definition xml:lang="en">Whether economic operator-related information can be supplemented even after the submission deadline. Additional Information This is specific to the information on the economic operator and not the actual offer. This does not apply to the requests for clarification.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLegalBasis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207541762" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Legal Basis</skos:prefLabel>
    <skos:definition xml:lang="en">The legal basis under which the procurement procedure takes place. Additional Information: For example European Directives or Regulations, national laws etc. The recommended code list is the example for the legal basis at the European level.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLegalFormType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/org#Organization" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Legal Form Type</skos:prefLabel>
    <skos:definition xml:lang="en">The classification of an Organisation according to legislation. Additional Information: Generally, this is defined for Tenderers who want to submit as an Organisation Group. Note that the codelist provided at national level should be used. (org:Organization)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLegalName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/org#Organization" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Legal Name</skos:prefLabel>
    <skos:definition xml:lang="en">The officially registered name of an organisation. (org:Organization)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 10/01/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLowestReceivedTenderValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Lowest Received Tender Value</skos:prefLabel>
    <skos:definition xml:lang="en">Amount of the Tender with the lowest value. Additional Information The value must correspond to an admissible tender. For example, tenders compliant with the procurement document requirements, not having an abnormally low price or cost, etc.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/12/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMainClassification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Purpose" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Main Classification</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the main Common Procurement Vocabulary code.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMainFeature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Procedure" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Main Feature</skos:prefLabel>
    <skos:definition xml:lang="en">Main features of the procedure and information about where the full rules for the procedure can be found. Additional Information: This information should be given when the procedure is not one of those mentioned in the procurement directives. This can be the case for example for concessions, for social and other specific services, and in case of voluntary publication of procurement procedures below the EU procurement thresholds. (epo:Procedure)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasManufacturerID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Manufacturer" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Manufacturer ID</skos:prefLabel>
    <skos:definition xml:lang="en">The manufacturer&#39;s identifier for the item.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasManufacturerItemID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AbstractItem" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Manufacturer Item ID</skos:prefLabel>
    <skos:definition xml:lang="en">The general identifier assigned to the concept as defined by the Manufacturer. ​</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 16/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumFrameworkAgreementAwardedValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#NoticeAwardInformation" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Maximum Framework Agreement Awarded Value</skos:prefLabel>
    <skos:definition xml:lang="en">The maximum value which can be spent through all the framework agreements announced in this notice, including options and renewals of contracts. Additional information: The value provided is a threshold value that implicity means that it cannot be exceeded however it may not be reached during the execution of a contract. The Framework Agreements in a CAN are to be traced back and added to provide this value.</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-118</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 03/12/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumNumberOfCandidates">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MultipleStageProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Maximum Number Of Candidates</skos:prefLabel>
    <skos:definition xml:lang="en">Maximum number of candidates to be invited for the second stage of the procedure. (epo:MultipleStageProcedureTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 22/08/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumNumberOfLotsToBeAwarded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Maximum Number Of Lots To Be Awarded</skos:prefLabel>
    <skos:definition xml:lang="en">The maximum number of lots for which contract(s) can be awarded to one tenderer. Additional information: This field is used to complement the SubmissionTerms (which are at the Lot level) for the Procedure level which is covered by the regulation (EU)-2015-1986 (modeled in the TED Standard Forms). (epo:ProcedureTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 22/08/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumNumberOfRenewals">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Maximum Number Of Renewals</skos:prefLabel>
    <skos:definition xml:lang="en">The maximum number of times the contract can be renewed. Additional Information By renewing, the buyer reserves the right (i.e. not an obligation) to renew the contract (i.e. extend its duration) without a new procurement procedure. For example, a contract may be valid for one year and the buyer may keep a possibility to renew it (e.g. once, twice) for another three months, if he is content with the services he received. PLEASE REVIEW THIS DEFINITION AGAIN WITH THE WORKING GROUP. It was originally taken from eForms. (epo:ContractTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumOrderQuantity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#CatalogueLine" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Maximum Order Quantity</skos:prefLabel>
    <skos:definition xml:lang="en">The maximum number of orderable units that can be ordered according to details provided in the catalogue line, such as price.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumParticipantsNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#FrameworkAgreementTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Maximum Participants Number</skos:prefLabel>
    <skos:definition xml:lang="en">The maximum number of participants in the framework agreement. Additional Information: Maximum number of tenderers who may be awarded a contract within the framework agreement. The number is a positive integer. (epo:FrameworkAgreementTerm)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-113</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 05/02/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumShare">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubcontractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Maximum Share</skos:prefLabel>
    <skos:definition xml:lang="en">The maximum proportion of something to be distributed. Additional Information: In the case of subcontracting the share may refer to the proportion of works, services or supplies being subcontracted. (epo:SubcontractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 17/09/2019 </skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMediumTenderPerLots">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Medium Tender Per Lots</skos:prefLabel>
    <skos:definition xml:lang="en">Tenders from medium-sized enterprise. &lt;u&gt;Additional Information:&lt;/u&gt; See Commission Recommendation 2003/361/EC. (epo:SubmissionStatisticalInformation)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMember">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#OrganisationGroup" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/org#Organization" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Member</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating a part of the instance of the concept.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMinimumNumberOfCandidates">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MultipleStageProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Minimum Number Of Candidates</skos:prefLabel>
    <skos:definition xml:lang="en">Minimum number of candidates to be invited for the second stage of the procedure. (epo:MultipleStageProcedureTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 22/08/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMinimumQuantityGuaranteedForDelivery">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#CatalogueLine" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Minimum Quantity Guaranteed For Delivery</skos:prefLabel>
    <skos:definition xml:lang="en">The minimum quantity of an item that is guaranteed by the seller to be delivered.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMinimumShare">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubcontractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Minimum Share</skos:prefLabel>
    <skos:definition xml:lang="en">The minimum proportion of something to be distributed. Additional Information: In the case of subcontracting the share may refer to the proportion of works, services or supplies being subcontracted. (epo:SubcontractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 17/09/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMinimumSubcontractorsProposedObligation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubcontractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Minimum Subcontractors Proposed Obligation</skos:prefLabel>
    <skos:definition xml:lang="en">The minimum percentage of the contract value that the contractor must subcontract. Additional information: This is used for the competitive procedure described in Title III of Directive 2009/81/EC. (epo:SubcontractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasModificationDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractModificationInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#con" />
    <skos:prefLabel xml:lang="en">has Modification Description</skos:prefLabel>
    <skos:definition xml:lang="en">An explanatory text about this context. (epo-con:ContractModificationInformation)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-202, TEDXML F20 VII.2.1</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 5/11/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasModificationReasonDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractModificationInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#con" />
    <skos:prefLabel xml:lang="en">has Modification Reason Description</skos:prefLabel>
    <skos:definition xml:lang="en">An explanation about the reasons for using the concept. (epo-con:ContractModificationInformation)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-201, TEDXML F20 VII.2.2.2, TEDXML F20 VII.2.2.4</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 05/11/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNationality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/person#Person" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Nationality</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the country code to which the instance of the concept officially belongs to.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNetMonetaryValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty" />
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Price" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Net Monetary Value</skos:prefLabel>
    <skos:definition xml:lang="en">The price amount of an Item exclusive of taxes and after subtracting price discounts.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNetQuantity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AbstractItem" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Net Quantity</skos:prefLabel>
    <skos:definition xml:lang="en">The net quantity of the item that is contained in each consumable unit, excluding any packaging materials.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNoNegotiationNecessary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MultipleStageProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has No Negotiation Necessary</skos:prefLabel>
    <skos:definition xml:lang="en">The buyer reserves the right to award the contract on the basis of the initial tenders without any further negotiations. Additional information: See Article 29(4) of Directive 2014/24/EU. (epo:MultipleStageProcedureTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNonAccessibilityCriterionJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SocialProcurement" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Non Accessibility Criterion Justification</skos:prefLabel>
    <skos:definition xml:lang="en">Reason for not applying accessibility criteria. (epo:SocialProcurement)</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BT-755</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 05/03/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNonAwardJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardOutcome" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Non Award Justification</skos:prefLabel>
    <skos:definition xml:lang="en">On hold; Enumeration.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNonElectronicSubmissionDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Non Electronic Submission Description</skos:prefLabel>
    <skos:definition xml:lang="en">Textual explanation of how non-electronic information is to be presented. (epo:SubmissionTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/07/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNonElectronicSubmissionJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Non Electronic Submission Justification</skos:prefLabel>
    <skos:definition xml:lang="en">Reason for not accepting electronic information.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNonPublicationJustification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#NonPublishedInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Non Publication Justification</skos:prefLabel>
    <skos:definition xml:lang="en">The reason why data is not published.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNoticeType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Notice" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Notice Type</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Notice Type.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNumberOfReviewRequests">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty" />
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ReviewRequestSummary" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Number Of Review Requests</skos:prefLabel>
    <skos:definition xml:lang="en">The number of requests the buyer received to review any of its decisions. (epo:ReviewRequestSummary)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNumberOfTenderersInvited">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Number Of Tenderers Invited</skos:prefLabel>
    <skos:definition xml:lang="en">Number of economic operators invited to tender. Additional Information This may be used for single-stage procedures or to indicate the number of candidates invited to tender in multi-stage procedures. (epo:SubmissionStatisticalInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 01/12/2020</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNutsCode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207541805" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Nuts Code</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Nomenclature of Territorial Units for Statistics code.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOfficialLanguage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Document" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Official Language</skos:prefLabel>
    <skos:definition xml:lang="en">The language(s) in which the instances of the given concepts are officially available. These linguistic versions are equally legally valid.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOpeningDateTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty" />
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#OpeningTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Opening Date Time</skos:prefLabel>
    <skos:definition xml:lang="en">Date and time for the opening of tenders. (epo:OpeningTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/03/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOpeningDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#OpeningTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Opening Description</skos:prefLabel>
    <skos:definition xml:lang="en">Further information about the opening of tenders. Additional Information For example, who may participate in the opening and whether any authorization is needed. (epo:OpeningTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/03/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOpeningURL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#OpeningTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Opening URL</skos:prefLabel>
    <skos:definition xml:lang="en">The identifier of the address of the Opening of Tenders. (epo:OpeningTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOptions">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Options</skos:prefLabel>
    <skos:definition xml:lang="en">The buyer reserves the right (not an obligation) for additional purchases from the contractor (while the contract is valid). (epo:ContractTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOptionsDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Options Description</skos:prefLabel>
    <skos:definition xml:lang="en">The motivation and details about additional purchases that the buyer may undertake while the contract is valid. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/04/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOrderabableUnitFactorRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Price" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Orderabable Unit Factor Rate</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOverallCostAwardCriteriaPonderation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardEvaluationTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Overall Cost Award Criteria Ponderation</skos:prefLabel>
    <skos:definition xml:lang="en">The weighting given to cost. Additional Information: This weighting covers usually all cost criteria against price or quality criteria. (epo:AwardEvaluationTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOverallPriceAwardCriteriaPonderation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardEvaluationTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Overall Price Award Criteria Ponderation</skos:prefLabel>
    <skos:definition xml:lang="en">The weighting given to price. Additional Information: This weighting covers usually all price criteria against cost or quality criteria. (epo:AwardEvaluationTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasOverallQualityAwardCriteriaPonderation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardEvaluationTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Overall Quality Award Criteria Ponderation</skos:prefLabel>
    <skos:definition xml:lang="en">The weighting given to quality. Additional Information: This weighting covers usually all quality criteria against price or cost criteria. (epo:AwardEvaluationTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasParticipationPayment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DesignContestRegimeTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Participation Payment</skos:prefLabel>
    <skos:definition xml:lang="en">Details on payments to participants (epo:DesignContestRegimeTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 09/11/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasPaymentArrangement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Payment Arrangement</skos:prefLabel>
    <skos:definition xml:lang="en">Information about financial clauses that will govern some economic aspects of the execution of the contract. Additional Information: These clauses usually refer to financial and payment provisions. This type of information should be structured instead of a free text in order to reuse it an ideal world. Unfortunately this is an information that in the real life no one is willing to provide pro-actively. WG Pending of discussion with eForms (epo:ContractTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasPerformanceConditions">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Performance Conditions</skos:prefLabel>
    <skos:definition xml:lang="en">The particular conditions and additional information related to the execution of the contract. Additional Information: For example, specific information about the place of performance, intermediary deliverables, compensation for damages, intellectual property rights. (epo:ContractTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 15/01/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasPerformingStaffQualificationInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Performing Staff Qualification Information</skos:prefLabel>
    <skos:definition xml:lang="en">Explanation as to if and/or when information of the persons to carry out the contract is to be provided. The codelist to be used is at-voc:requirement-stage which is available at http://publications.europa.eu/resource/dataset/requirement-stage</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasPlaceOfPerformanceAdditionalInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractTerm" />
