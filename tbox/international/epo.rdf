    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
    <skos:prefLabel xml:lang="en">has Reject Reason Description</skos:prefLabel>
    <skos:definition xml:lang="en">Explanatory text about the motive of the refusal. (epo-ful:ReceiptAdviceInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2026</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasRemittanceInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#PaymentInstructionsInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#inv" />
    <skos:prefLabel xml:lang="en">has Remittance Information</skos:prefLabel>
    <skos:definition xml:lang="en">A textual value used to establish a link between the payment and the Invoice, issued by the Seller. (epo-inv:PaymentInstructionsInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 11/07/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasRequestedDeliveryPeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
