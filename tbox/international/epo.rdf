  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAccountingCost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Invoice" />
    <rdfs:domain rdf:nodeID="b207541057" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ord" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#inv" />
    <skos:prefLabel xml:lang="en">has Accounting Cost</skos:prefLabel>
    <skos:definition xml:lang="en">The accounting reference used by the Buyer to specify the account to which the order and the corresponding invoice are booked. (epo-ord:Order) The accounting reference used by the Buyer to specify the account to which the order and the corresponding invoice are booked. (epo-ord:OrderLine)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 26/01/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAddressURL">
