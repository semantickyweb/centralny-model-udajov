    <rdfs:subClassOf rdf:nodeID="b207541040" />
    <skos:prefLabel xml:lang="en">Originator Information</skos:prefLabel>
    <skos:definition xml:lang="en">Information about the Originator of the Order.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 20/03/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#OriginatorRequest">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
