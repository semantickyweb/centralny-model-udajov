    <rdfs:subClassOf rdf:nodeID="b207541045" />
    <skos:prefLabel xml:lang="en">Transport Means</skos:prefLabel>
    <skos:definition xml:lang="en">Description of a particular vehicle or vessel used for the conveyance of goods or persons.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TransportMeansOperator">
