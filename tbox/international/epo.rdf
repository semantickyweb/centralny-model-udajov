    <skos:historyNote xml:lang="en">WG approval 30/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#SelectionCriteriaSummary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#QualificationCriteriaSummary" />
