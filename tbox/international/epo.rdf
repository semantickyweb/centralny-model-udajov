    <rdfs:subClassOf rdf:nodeID="b207541370" />
    <skos:prefLabel xml:lang="en">Request For Offer</skos:prefLabel>
    <skos:definition xml:lang="en">A Document sent by the Buyer to the Economic Operator, requesting the submission of a commercial proposal to supply goods, services, or works under specified conditions.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 16/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#ReviewInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
