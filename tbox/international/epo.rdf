    <skos:definition xml:lang="en">Economic Operator (who is not a Subcontractor) on which the Tenderer relies upon, to meet Selection Criteria.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#RequestForOffer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
