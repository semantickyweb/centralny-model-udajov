    <skos:definition xml:lang="en">The amount of Tenders received from economic operators that are SMEs without taking into account Subcontractors. (epo:SubmissionStatisticalInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasSellerOrderID">
