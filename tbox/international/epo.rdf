    <skos:historyNote xml:lang="en">WG approval 09/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasTaxBreakdownInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
