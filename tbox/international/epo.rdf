    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBargainPrice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardOutcome" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Bargain Price</skos:prefLabel>
    <skos:definition xml:lang="en">The value of procured supplies that have used a particularly advantageous opportunity available for a very short time at a value considerably lower than normal market prices.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 23/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBuyerItemID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AbstractItem" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Buyer Item ID</skos:prefLabel>
    <skos:definition xml:lang="en">The general identifier assigned to the concept as defined by the Buyer.​</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 16/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBuyerLegalType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/org#Organization" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Buyer Legal Type</skos:prefLabel>
    <skos:definition xml:lang="en">A category that indicates the right of an Organisation to play the role of a buyer. Additional Information: The category also effects the rules that the buyer has to abide to within the public procurement procedure.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBuyerLegalTypeDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/org#Organization" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Buyer Legal Type Description</skos:prefLabel>
    <skos:definition xml:lang="en">Self-explanatory text about the Buyer Legal Type. Additional information: This field is used when the Buyer Legal Type is not available in the controlled list at-voc:buyer-legal-type . This is necessary in to cover data provided in the TED Standard Forms. It shall be deprecated in the future. (org:Organization)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 06/09/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDeliveryPeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DeliveryInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ord" />
    <skos:prefLabel xml:lang="en">has Delivery Period</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the time range for the delivery.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLotAwardCombination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Lot Award Combination</skos:prefLabel>
    <skos:definition xml:lang="en">The contracting authority reserves the right to award contracts combining lots or groups of lots. Additional Information: This property contains information about the Lots concerned. This property is required by the regulation (EU)-2015-1986 (modeled in the TED Standard Forms). (epo:ProcedureTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 23/08/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMainActivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/org#Organization" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Main Activity</skos:prefLabel>
    <skos:definition xml:lang="en">The principal sectoral area in which an organisation operates. Additional information: The activities associated with buyers are derived from the top level of the Classification of the functions of the government (COFOG) from the United Nations Statistics Division. The activities associated with buyer are derived from sectors explicitly falling within the sectoral directive (2014/25/EU Art. 8 - Art. 14).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMainActivityDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/org#Organization" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Main Activity Description</skos:prefLabel>
    <skos:definition xml:lang="en">Self-explanatory text about the Main Activity . Additional information: This field is used when the Main Activity is not available in the controlled list at-voc:main-activity-type . This is necessary in to cover data provided in the TED Standard Forms. It shall be deprecated in the future. (org:Organization)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 06/09/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumLotSubmissionAllowed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Maximum Lot Submission Allowed</skos:prefLabel>
    <skos:definition xml:lang="en">The total number of lots for which one Tenderer can submit Tenders. Additional information: This field is used to complement the SubmissionTerms (which are at the Lot level) for the Procedure level which is covered by the regulation (EU)-2015-1986 (modeled in the TED Standard Forms). (epo:ProcedureTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 12/12/2018</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNationalProcedureRules">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has National Procedure Rules</skos:prefLabel>
    <skos:definition xml:lang="en">The resource identifier where the information about the national rules applicable to the procedure can be found. (epo:ProcedureTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 02/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNonAwardedContractNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#LotAwardOutcome" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Non Awarded Contract Number</skos:prefLabel>
    <skos:definition xml:lang="en">The number the contract would have had if it had been awarded. Additional information: This field is provided to support the data provided in the TED Standard Forms, and it should be discontinued in the future. (epo:LotAwardOutcome)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 06/09/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNonAwardedContractTitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#LotAwardOutcome" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Non Awarded Contract Title</skos:prefLabel>
    <skos:definition xml:lang="en">The title the contract would have had if it had been awarded. Additional information: This field is provided to support the data provided in the TED Standard Forms, and it should be discontinued in the future. (epo:LotAwardOutcome)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 06/09/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasQualificationSystemDuration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MultipleStageProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2006/time#Duration" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Qualification System Duration</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating a Qualification System has a Duration.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasQualificationSystemRenewalDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#MultipleStageProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Qualification System Renewal Description</skos:prefLabel>
    <skos:definition xml:lang="en">Explanation of how a Qualification System is re-established. Additional information: A Qualification System qualifies an economic operator to take part in a tendering process. Usually, in such cases the economic operator passes the Exclusion Grounds and Selection Criteria. (epo:MultipleStageProcedureTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 26/03/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasReceiptExpressionDeadline">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Receipt Expression Deadline</skos:prefLabel>
    <skos:definition xml:lang="en">Time limit for receipt of expressions of interest. Pending of review by the WG (epo:SubmissionTerm)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isBasedOnImplementingRegulation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Notice" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">is Based On Implementing Regulation</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates under which Implementing Regulation a Notice is created.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isOneLotOnlyAllowed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcedureTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">is One Lot Only Allowed</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates whether tenders may be submitted for only one Lot. Additional information: This field is used to complement the SubmissionTerms (which are at the Lot level) for the Procedure level which is covered by the regulation (EU)-2015-1986 (modeled in the TED Standard Forms). (epo:ProcedureTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 23/08/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isResponsibilityOfBuyer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Procedure" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Buyer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">is Responsibility Of Buyer</skos:prefLabel>
    <skos:definition xml:lang="en">The buyer in charge of the procedure.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isSubordinatedToContract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#PostAwardCatalogue" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Contract" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">is Subordinated To Contract</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating that the instance of the concept is governed by a specific Contract.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#providesRulingOnRemedy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ReviewDecision" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">provides Ruling On Remedy</skos:prefLabel>
    <skos:definition xml:lang="en">States the measures to be taken after a review procedure.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#signedByBuyer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Contract" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Buyer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">signed By Buyer</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Buyer that signs the instance of the concept.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#signedByContractor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Contract" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Contractor" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">signed By Contractor</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Contractor that signs the instance of the concept.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCertification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207540638" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AbstractItem" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Certificate" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Certification</skos:prefLabel>
    <skos:definition xml:lang="en">Relation to the proof of conformance.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 30/05/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#relatesToEFormSectionIdentifier">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207541695" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ContractModificationInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#con" />
    <skos:prefLabel xml:lang="en">relates To E Form Section Identifier</skos:prefLabel>
    <skos:definition xml:lang="en">Is about a specific eForms section.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasVehicleSegmentID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#TransportMeans" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Vehicle Segment ID</skos:prefLabel>
    <skos:definition xml:lang="en">The identifier of a part of the Transport Means.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 25/06/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#conformsToLegalBasis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Notice" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">conforms To Legal Basis</skos:prefLabel>
    <skos:definition xml:lang="en">The Notice was designed in accordance with the given legal basis. Additional Information: This Notice can be used for Procedures which do not have the same legal basis. This holds for standard forms.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#AwardOutcome">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#ContextualProjection" />
    <rdfs:subClassOf rdf:nodeID="b207541340" />
    <rdfs:subClassOf rdf:nodeID="b207541429" />
    <rdfs:subClassOf rdf:nodeID="b207540370" />
    <skos:prefLabel xml:lang="en">Award Outcome</skos:prefLabel>
    <skos:definition xml:lang="en">Result concerning the competition that was attributed by the Awarder.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 19/03/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#indicatesAwardToWinner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#TenderAwardOutcome" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Winner" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">indicates Award To Winner</skos:prefLabel>
    <skos:definition xml:lang="en">Reveals the winner to whom the tender award outcome is attributed.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasSchemeVersion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Scheme Version</skos:prefLabel>
    <skos:definition xml:lang="en">The version of the identification scheme. (adms:Identifier)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#refersToNoticeAwardInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207540521" />
    <rdfs:domain rdf:nodeID="b207540242" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#NoticeAwardInformation" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">refers To Notice Award Information</skos:prefLabel>
    <skos:definition xml:lang="en">Reference to a Notice Award Information.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasElectronicDigest">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Document" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Document" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Electronic Digest</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the digital summary that represents the content of the instance of the concept.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasCertificationNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Certificate" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Certification Number</skos:prefLabel>
    <skos:definition xml:lang="en">The unique identifier of the certificate. (epo:Certificate)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 26/07/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNonEUReceivedTenders">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#SubmissionStatisticalInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Non EU Received Tenders</skos:prefLabel>
    <skos:definition xml:lang="en">The amount of tenders received from economic operators in non-EU countries. (epo:SubmissionStatisticalInformation)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#needsToBeATenderer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Winner" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Tenderer" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">needs To Be A Tenderer</skos:prefLabel>
    <skos:definition xml:lang="en">The Winner must be a Tenderer.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#describesProfessionRelevantLaw">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProfessionalSuitabilitySummary" />
