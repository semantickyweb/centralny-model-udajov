    <skos:prefLabel xml:lang="en">has Despatcher Consignment ID</skos:prefLabel>
    <skos:definition xml:lang="en">The identifier of the the Consignment given by the Despatcher.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 10/06/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasFreightCharge">
