  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAttributeType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ItemProperty" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Attribute Type</skos:prefLabel>
    <skos:definition xml:lang="en">The property defined in a classification scheme. Additional Information: For example, the following two properties are defined in the ECLASS classification of goods and services: (0173-1#02-AAA026#007) drilling diameter: drilling diameter, (0173-1#02-AAA030#007) flange diameter: flange diameter . (epo-cat:ItemProperty)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 28/07/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasAwardCriteriaStatedInProcurementDocuments">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardCriterion" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Award Criteria Stated In Procurement Documents</skos:prefLabel>
    <skos:definition xml:lang="en">The Award Criteria are provided in the Procurement Documents. (epo:AwardCriterion)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 26/03/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBestBeforeDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Batch" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Best Before Date</skos:prefLabel>
    <skos:definition xml:lang="en">The day until which the quality of the item will remain optimal. (epo-cat:Batch)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 10/03/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasBrand">
