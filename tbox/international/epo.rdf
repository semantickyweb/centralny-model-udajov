    <skos:historyNote xml:lang="en">WG Approval 5/11/2019</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasProcurementHighestReceivedTenderValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#NoticeAwardInformation" />
