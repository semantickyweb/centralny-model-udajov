    <skos:definition xml:lang="en">https://test-docs.peppol.eu/logistics/transport-execution/codelist/DocumentStatusCode/</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasDocumentType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Document" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Document Type</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Document Type.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasESenderDispatchDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Notice" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has E Sender Dispatch Date</skos:prefLabel>
    <skos:definition xml:lang="en">The date and time the notice was transmitted electronically by the eSender to the Publications Office of the European Union. Additional Information: Typically, eSenders include national Official Journals, Buyers sending a large number of electronic Notices, public or private bodies acting on behalf of Buyers and eProcurement software developers. (epo:Notice)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 20/06/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasEndpointIdentifier">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/m8g/Channel" />
    <rdfs:range rdf:resource="http://www.w3.org/ns/adms#Identifier" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Endpoint Identifier</skos:prefLabel>
    <skos:definition xml:lang="en">The identifier of the specific location, address, or interface where a system, service, or application can be accessed.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasHandlingInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:nodeID="b207541143" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
    <skos:prefLabel xml:lang="en">has Handling Instruction</skos:prefLabel>
    <skos:definition xml:lang="en">Instruction on how to handle the Goods Items during transportation. (epo-ful:Consignment) Instruction on how to handle the Goods Items during transportation. (epo-ful:TransportHandlingUnit)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 05/06/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasLiteralValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ItemProperty" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Literal Value</skos:prefLabel>
    <skos:definition xml:lang="en">Simple value of the property, which is defined in a classification scheme. Additional Information: For example, the (0173-1#02-AAV139#001) coating 1 of an optical material has value of &quot;silver&quot;. This simple literal value is for the cases when the property value does not have units, in which case the qualifiedValue shall be used. (epo-cat:ItemProperty)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 28/07/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMaximumTemperature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#TemperatureSpecification" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Maximum Temperature</skos:prefLabel>
    <skos:definition xml:lang="en">The highest tolerated temperature.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 18/06/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasMinimumTemperature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#TemperatureSpecification" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Minimum Temperature</skos:prefLabel>
    <skos:definition xml:lang="en">The lowest tolerated temperature.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 18/06/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasNetVolume">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AbstractContainer" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Quantity" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
