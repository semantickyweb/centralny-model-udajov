    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Qualification Criteria Stated In Notice</skos:prefLabel>
    <skos:definition xml:lang="en">The Qualification Criteria is specified in the Notice. (epo:QualificationCriterion)</skos:definition>
    <skos:historyNotice xml:lang="en">WG approval 09/09/2025</skos:historyNotice>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasRejectReasonDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ReceiptAdviceInformation" />
