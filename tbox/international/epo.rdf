  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasClassificationScheme">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ItemProperty" />
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Classification Scheme</skos:prefLabel>
    <skos:definition xml:lang="en">The classification scheme where a property is defined. Additional Information: For example, the following two properties are defined in the ECLASS classification of goods and services: (0173-1#02-AAA026#007) drilling diameter: drilling diameter, (0173-1#02-AAA030#007) flange diameter: flange diameter . (epo-cat:ItemProperty)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 28/07/2022</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasConcessionEstimatedValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ConcessionEstimate" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Concession Estimated Value</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the estimated Monetary Value of the Concession.</skos:definition>
