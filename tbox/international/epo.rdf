    <skos:prefLabel xml:lang="en">Tax Information</skos:prefLabel>
    <skos:definition xml:lang="en">Information about the imposition of mandatory levies required by law.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 25/04/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TechnicalAbilitySummary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
