    <rdfs:subClassOf rdf:nodeID="b207540326" />
    <skos:prefLabel xml:lang="en">Delivery Information</skos:prefLabel>
    <skos:definition xml:lang="en">Information about the timing, the delivery destination, the delivery agreement and the involved parties.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 16/05/2023</skos:historyNote>
  </rdf:Description>
