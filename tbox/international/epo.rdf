    <skos:prefLabel xml:lang="en">Notice CEI</skos:prefLabel>
    <skos:definition xml:lang="en">Call for Expression of Interest for purchases below the Public Procurement Directive’s threshold as defined in the Financial Regulation applicable to the general budget of the Union.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
