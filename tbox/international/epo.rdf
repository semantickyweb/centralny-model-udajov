    <skos:definition xml:lang="en">Indicates whether the container or part of the container is to be sent back. (epo-ful:AbstractContainer)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isSecurityClearanceRequired">
