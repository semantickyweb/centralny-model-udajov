    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#AbstractItem" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">has Accessory Item</skos:prefLabel>
