    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#StandardFormsNotice" />
    <skos:prefLabel xml:lang="en">Design Contest- D25</skos:prefLabel>
    <skos:definition xml:lang="en">Design Contest Notice under Directive 25.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 16/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#DesignContestNotice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#CompetitionNotice" />
    <skos:prefLabel xml:lang="en">Design Contest Notice</skos:prefLabel>
    <skos:definition xml:lang="en">Announcement of a call for competition concerning the acquisition, mainly in the fields of town and country planning, architecture and engineering or data processing, of a plan or design selected by a jury.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#DesignContestResult-D24">
