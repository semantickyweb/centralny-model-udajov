  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#foreseesSubcontractor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207541184" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#Subcontractor" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">foresees Subcontractor</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating that an Organization plans to have a Subcontractor. Additional information: In eForms, in a Result Notice, the foreseen Subcontractors in a Tender are associated to the Organization that proposes the Subcontractors. The Subcontractor is associated to the Organization, rather than the Tenderer, so that, in the case of multiple Organizations being a Tenderer, it is clear to which Organization the proposed Subcontractor is associated.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 26/11/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasActualDeliveryDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#DeliveryInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ord" />
    <skos:prefLabel xml:lang="en">has Actual Delivery Date</skos:prefLabel>
    <skos:definition xml:lang="en">The date when the Delivery occured. (epo-ord:DeliveryInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2026</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasApproximateGroupFrameworkAgreementValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
