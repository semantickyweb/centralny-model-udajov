    <owl:incompatibleWith>4.2.0</owl:incompatibleWith>
    <dcterms:description xml:lang="en">The eProcurement Ontology Notice core describes the concepts and properties representing the European Public Procurement Notice domain. The provision of these semantics offers the basis for a common understanding of the domain for all stakeholders ensuring the quality of data exchange and transparency. The ontology restrictions are published in a separate artefact.</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-10-10</dcterms:issued>
    <dcterms:title xml:lang="en">eProcurement Ontology Notice - core</dcterms:title>
