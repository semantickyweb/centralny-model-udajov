    <rdfs:domain rdf:nodeID="b207541437" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ord" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#inv" />
    <skos:prefLabel xml:lang="en">has Total Tax Inclusive Amount</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the overall Monetary Value with Tax.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#describesObjectiveParticipationRules">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
