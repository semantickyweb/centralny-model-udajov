    <skos:definition xml:lang="en">Voluntary Completion Notice for purchases below the Public Procurement Directive threshold.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#NoticeT01">
