    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#inv" />
    <skos:prefLabel xml:lang="en">has Tax Exemption Reason Description</skos:prefLabel>
    <skos:definition xml:lang="en">An explanation on why the amount is exempted from tax or why no tax is being charged according to the legislation, expressed as a text. (epo-inv:TaxBreakdownInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 11/07/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasVATExemptionReason">
