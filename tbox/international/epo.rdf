    <skos:historyNote xml:lang="en">WG Approval 02/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#awa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology" />
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-06-01</dcterms:created>
    <rdfs:label xml:lang="en">eProcurement Ontology Awarding - core</rdfs:label>
    <owl:imports rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <owl:imports rdf:resource="http://www.w3.org/2006/time" />
