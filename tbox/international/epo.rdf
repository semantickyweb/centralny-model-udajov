    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
    <skos:prefLabel xml:lang="en">is Hazardous Risk</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates whether some of the contained Goods Items are hazardous. (epo-ful:AbstractContainer) Indicates whether some of the contained Goods Items are hazardous. (epo-ful:Consignment)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isInStock">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AbstractItem" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <skos:prefLabel xml:lang="en">is In Stock</skos:prefLabel>
    <skos:definition xml:lang="en">Indicator whether an item is in the supplier&#39;s stock. If not in stock the supplier has to order the item. (epo-cat:AbstractItem)</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isNonDisclosureAgreementRequired">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#NonDisclosureAgreementTerm" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">is Non Disclosure Agreement Required</skos:prefLabel>
    <skos:definition xml:lang="en">A non-disclosure agreement is needed. Additional information: A non-disclosure agreement is a Contract between different parties which ensures information is not shared with other parties. (epo:NonDisclosureAgreementTerm)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 26/03/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isOrderable">
