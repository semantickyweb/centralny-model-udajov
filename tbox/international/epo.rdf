    <skos:definition xml:lang="en">The monetary amount to which the multiplier factor is applied in calculating the amount of this allowance, charge or tax.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isContractedItem">
