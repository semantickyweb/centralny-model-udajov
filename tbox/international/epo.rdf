    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#eFormsNotice" />
