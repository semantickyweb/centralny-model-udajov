    <skos:prefLabel xml:lang="en">Technical Ability Summary</skos:prefLabel>
    <skos:definition xml:lang="en">Overview of the expertise required for the economic operator to execute the contract.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 19/03/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TechnicalSpecification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">Technical Specification</skos:prefLabel>
    <skos:definition xml:lang="en">A set of documented Requirements applicable to the object of the Procurement. Additional Information: A specification often includes technical standards.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 20/04/2021</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#Technique">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:subClassOf rdf:nodeID="b207541540" />
    <rdfs:subClassOf rdf:nodeID="b207541718" />
    <skos:prefLabel xml:lang="en">Technique</skos:prefLabel>
    <skos:definition xml:lang="en">Method used for conducting Procurement Procedures. Several Techniques can be combined in one single Procurement Procedure (e.g. eAuction can be carried out in a Framework Agreement or DPS).</skos:definition>
    <skos:editorialNote xml:lang="en">Used by eForms BG-706</skos:editorialNote>
    <skos:historyNote xml:lang="en">WG Approval 19/09/2019</skos:historyNote>
  </rdf:Description>
