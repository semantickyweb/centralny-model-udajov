    <skos:prefLabel xml:lang="en">Notice E4</skos:prefLabel>
    <skos:definition xml:lang="en">Voluntary Award Notice for purchases below the Public Procurement Directive threshold.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#NoticeE5">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
