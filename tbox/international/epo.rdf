    <skos:definition xml:lang="en">Relation indicating the sought time range for the delivery.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasScorePoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#EvaluationCriterion" />
