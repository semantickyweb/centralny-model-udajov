    <skos:prefLabel xml:lang="en">has Maskable Property</skos:prefLabel>
    <skos:definition xml:lang="en">Resource that has a hidden value. (epo:NonPublishedInformation)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasResponseStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#CatalogueResponseInformation" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#cat" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ord" />
    <skos:prefLabel xml:lang="en">has Response Status</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the response status.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasStandstillPeriodEndDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#AwardDecisionNotification" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#awa" />
    <skos:prefLabel xml:lang="en">has Standstill Period End Date</skos:prefLabel>
    <skos:definition xml:lang="en">The end date for the mandatory minimum time frame between the communication of a contract award decision and the formal conclusion of the contract, during which unsuccessful Tenderers have the opportunity to challenge the award before it becomes legally binding. (epo-awa:AwardDecisionNotification)</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasTaxPointDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Invoice" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#inv" />
    <skos:prefLabel xml:lang="en">has Tax Point Date</skos:prefLabel>
    <skos:definition xml:lang="en">The date when the tax becomes accountable for the Seller and for the Buyer. Additional Information: That date can be determined and differs from the date of issue of the invoice, according to the national implementation of the directive. (epo-inv:Invoice)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 11/07/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasTaxPointDateCode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Invoice" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#inv" />
    <skos:prefLabel xml:lang="en">has Tax Point Date Code</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the a Tax Date.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasUnknownUsageOfSelectionCriterionType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#ProcurementElement" />
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Unknown Usage Of Selection Criterion Type</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating that it is not known whether a Selection Criterion type is to be used or not.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#providesEvidence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
