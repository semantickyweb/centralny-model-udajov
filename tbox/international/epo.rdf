    <skos:prefLabel xml:lang="en">refers To Catalogue</skos:prefLabel>
    <skos:definition xml:lang="en">Additional information: If an order refers to multiple catalogues then all these catalogues ideally are subordinated to the same contract. Some countries however may allow multiple contracts per order (i.e Italy).</skos:definition>
  </rdf:Description>
