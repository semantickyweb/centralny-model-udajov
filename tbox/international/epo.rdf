    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#NoticeE4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
