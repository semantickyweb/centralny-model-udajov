    <rdfs:seeAlso rdf:resource="https://op.europa.eu/en/web/eu-vocabularies/e-procurement" />
    <owl:incompatibleWith>4.2.0</owl:incompatibleWith>
    <dcterms:description xml:lang="en">The eProcurement Ontology Awarding core describes the concepts and properties representing the European Public Procurement Awarding domain. The provision of these semantics offers the basis for a common understanding of the domain for all stakeholders ensuring the quality of data exchange and transparency. The ontology restrictions are published in a separate artefact.</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-10-10</dcterms:issued>
    <dcterms:title xml:lang="en">eProcurement Ontology Awarding - core</dcterms:title>
    <dcterms:publisher>http://publications.europa.eu/resource/authority/corporate-body/PUBL</dcterms:publisher>
    <dcterms:license>© European Union, 2014. Unless otherwise noted, the reuse of the Ontology is authorised under the European Union Public Licence v1.2 (https://eupl.eu/).</dcterms:license>
    <owl:versionIRI rdf:resource="http://data.europa.eu/a4g/ontology#awa-5.2.0" />
    <ns5:preferredNamespacePrefix>epo</ns5:preferredNamespacePrefix>
    <ns5:preferredNamespaceUri>http://data.europa.eu/a4g/ontology#</ns5:preferredNamespaceUri>
  </rdf:Description>
