    <rdfs:subClassOf rdf:nodeID="b207541554" />
    <rdfs:subClassOf rdf:nodeID="b207541347" />
    <rdfs:subClassOf rdf:nodeID="b207541472" />
    <rdfs:subClassOf rdf:nodeID="b207541477" />
    <rdfs:subClassOf rdf:nodeID="b207542013" />
    <rdfs:subClassOf rdf:nodeID="b207542005" />
    <rdfs:subClassOf rdf:nodeID="b207541985" />
    <rdfs:subClassOf rdf:nodeID="b207541946" />
    <rdfs:subClassOf rdf:nodeID="b207540545" />
    <rdfs:subClassOf rdf:nodeID="b207540393" />
    <skos:prefLabel xml:lang="en">Contract Modification Notice</skos:prefLabel>
    <skos:definition xml:lang="en">An announcement of the Modification of a Contract/Concession during its term by a Procuring Entity.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#ContractTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#Term" />
    <rdfs:subClassOf rdf:nodeID="b207541570" />
    <rdfs:subClassOf rdf:nodeID="b207541555" />
    <rdfs:subClassOf rdf:nodeID="b207541740" />
    <rdfs:subClassOf rdf:nodeID="b207541741" />
    <rdfs:subClassOf rdf:nodeID="b207541742" />
    <rdfs:subClassOf rdf:nodeID="b207541743" />
    <rdfs:subClassOf rdf:nodeID="b207541736" />
    <rdfs:subClassOf rdf:nodeID="b207541737" />
    <rdfs:subClassOf rdf:nodeID="b207541738" />
    <rdfs:subClassOf rdf:nodeID="b207541739" />
    <rdfs:subClassOf rdf:nodeID="b207541734" />
