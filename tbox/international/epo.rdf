    <skos:prefLabel xml:lang="en">Notice E1</skos:prefLabel>
    <skos:definition xml:lang="en">Voluntary Pre-market Consultation Notice for purchases below the Public Procurement Directive threshold.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#NoticeE2">
