    <skos:prefLabel xml:lang="en">Carrier</skos:prefLabel>
    <skos:definition xml:lang="en">The Role of an Agent who handles the physical Delivery/Transportation of the (Despatched) Shipment. Additional Information: This Role is often referred to as the deliverer.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 14/05/2024</skos:historyNote>
  </rdf:Description>
