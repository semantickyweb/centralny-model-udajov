    <rdfs:subClassOf rdf:nodeID="b207541235" />
    <rdfs:subClassOf rdf:nodeID="b207541210" />
    <rdfs:subClassOf rdf:nodeID="b207540478" />
    <rdfs:subClassOf rdf:nodeID="b207540352" />
    <rdfs:subClassOf rdf:nodeID="b207540294" />
    <rdfs:subClassOf rdf:nodeID="b207540692" />
    <rdfs:subClassOf rdf:nodeID="b207540564" />
    <rdfs:subClassOf rdf:nodeID="b207540505" />
    <skos:prefLabel xml:lang="en">Consignment</skos:prefLabel>
    <skos:definition xml:lang="en">A batch of goods destined for or delivered to someone. Additional information: Consignment is a Transport Agreement between the Despatcher and the Consignee as to who and how the goods are despatched and received.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 14/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#ContextDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">Context Description</skos:prefLabel>
    <skos:definition xml:lang="en">A description concerning a Procurement Object or a Notice in a specific Situation Context. Additional Information: The description has its own identity (+I) but is dependent (+D) on the concerned Entity. We say that ContextDescription *concerns* an Entity.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#ContractAmendment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#con" />
    <rdfs:subClassOf rdf:nodeID="b207541907" />
    <rdfs:subClassOf rdf:nodeID="b207542064" />
    <rdfs:subClassOf rdf:nodeID="b207541431" />
    <rdfs:subClassOf rdf:nodeID="b207541357" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#Contract" />
    <skos:prefLabel xml:lang="en">Contract Amendment</skos:prefLabel>
    <skos:definition xml:lang="en">A change to an existing Contract that is agreed by the contracting parties.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#ContractInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ord" />
