    <skos:prefLabel xml:lang="en">Shipment Information</skos:prefLabel>
    <skos:definition xml:lang="en">Information about the transportation of an identifiable collection of Goods Items from the Despatcher to the Consignee.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#ShipmentStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#ful" />
