    <skos:definition xml:lang="en">The Role of an Agent that is informed about the arrival of a Shipment at a destination. Additional information: This could be for example customs and excise.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#PaymentInstructionsInformation">
