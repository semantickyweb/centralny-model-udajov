    <rdfs:subClassOf rdf:nodeID="b207541780" />
    <rdfs:subClassOf rdf:nodeID="b207540258" />
    <rdfs:subClassOf rdf:nodeID="b207540269" />
    <skos:prefLabel xml:lang="en">Contract Lot Completion Information</skos:prefLabel>
    <skos:definition xml:lang="en">Information related to a given Lot at the end of the procurement.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#ContractModificationNotice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
