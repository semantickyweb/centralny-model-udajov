    <skos:definition xml:lang="en">Relation indicating the association with an Item.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#isReturnableMaterial">
