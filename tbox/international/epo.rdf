    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">describes Profession Relevant Law</skos:prefLabel>
    <skos:definition xml:lang="en">Explanatory text about the law concerning the profession. (epo:ProfessionalSuitabilitySummary)</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 02/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#specifiesProcurementCriteriaSummary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#Procedure" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#ProcurementCriteriaSummary" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">specifies Procurement Criteria Summary</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the Procurement Criteria Summary to be used.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 25/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#foreseesProcurementObject">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:resource="http://data.europa.eu/a4g/ontology#PlannedProcurementPart" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#ProcurementObject" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">foresees Procurement Object</skos:prefLabel>
    <skos:definition xml:lang="en">Relation indicating the instance of a Procurement Object that is planned. Additional Information: The properties of the Procurement Object that is foreseen should be read as foreseen properties. For example, Procedure isSMESuitable should be read as Procedure foreseesToBeSMESuitable. For example, Procedure isFundedBy should be read as Procedure foreseesToBeFundedBy.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasApproximateFrameworkAgreementValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
    <rdfs:domain rdf:nodeID="b207542038" />
    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#MonetaryValue" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">has Approximate Framework Agreement Value</skos:prefLabel>
    <skos:definition xml:lang="en">The estimated value to be spent within the Framework Agreement(s). Additional information: In the case of an Award Decision for a Lot, this relation represents the estimated value for the awarded Framework Agreement. In the case of a Notice, this relation represents the estimated value for all Framework Agreements covered by the Notice.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasTotalTaxInclusiveAmount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty" />
