  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TenderClarification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#eva" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#ProcurementDocument" />
    <rdfs:subClassOf rdf:nodeID="b207541933" />
    <skos:prefLabel xml:lang="en">Tender Clarification</skos:prefLabel>
    <skos:definition xml:lang="en">A Document sent by the Tenderer to the Buyer in response to the Tender Clarification Request. Additional Information: The Tender Clarification may not alter the Tender.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 16/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TenderClarificationRequest">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#eva" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#Document" />
    <rdfs:subClassOf rdf:nodeID="b207540822" />
    <rdfs:subClassOf rdf:nodeID="b207540814" />
    <rdfs:subClassOf rdf:nodeID="b207541886" />
    <rdfs:subClassOf rdf:nodeID="b207541381" />
    <rdfs:subClassOf rdf:nodeID="b207541408" />
    <skos:prefLabel xml:lang="en">Tender Clarification Request</skos:prefLabel>
    <skos:definition xml:lang="en">A demand for elucidation of specific aspects of the Tender. Additional Information: This request and its answer may not alter the Tender.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#UniqueResponsibleOfTheProcurement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
