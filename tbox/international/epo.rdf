    <skos:historyNote xml:lang="en">WG approval 09/02/2023</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#PIN-CFCSocial-D25">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#StandardFormsNotice" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#PIN-CFCSocialNotice" />
    <skos:prefLabel xml:lang="en">PI N- CFC Social- D25</skos:prefLabel>
    <skos:definition xml:lang="en">Prior information notice used as a Call For Competition using the light regime under Directive 25. Additional information: The light regime is generally used for procurement of social and other specific services. The light regime may enable reserving Contracts for social enterprises and sheltered workshops.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 16/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#PIN-CFCSocialNotice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#CompetitionNotice" />
    <skos:prefLabel xml:lang="en">PI N- CFC Social Notice</skos:prefLabel>
    <skos:definition xml:lang="en">Announcement of intentions of planned procurements used as a call for competition concerning contracts for social and other specific services.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#PIN-CFCSocialNotice-D25">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#StandardFormsNotice" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#PIN-CFCSocialNotice" />
    <skos:prefLabel xml:lang="en">PI N- CFC Social Notice- D25</skos:prefLabel>
    <skos:definition xml:lang="en">Additional information: Social and other specific services – utilities</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#PIN-CFCStandard-D24">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#StandardFormsNotice" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#PIN-CFCStandardNotice" />
    <skos:prefLabel xml:lang="en">PI N- CFC Standard- D24</skos:prefLabel>
    <skos:definition xml:lang="en">Prior information notice used as a Call For Competition using the standard regime under Directive 24. Additional information: The standard regime refers to the core rules for public procurement, which mandates that public authorities award contracts in compliance with EU principles of equal treatment and transparency.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 16/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#PIN-CFCStandardNotice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#not" />
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/a4g/ontology#CompetitionNotice" />
    <skos:prefLabel xml:lang="en">PI N- CFC Standard Notice</skos:prefLabel>
    <skos:definition xml:lang="en">Announcement of intentions of planned procurements used as a call for competition. Additional information: For restricted procedures and competitive procedures with negotiation, sub-central contracting authorities may use a prior information notice as a call for competition pursuant to the relevant article of the Directive.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 09/10/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#PIN-RTL-D24">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
