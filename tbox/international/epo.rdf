    <skos:definition xml:lang="en">Relation indicating the language in which the Procurement Documents should be submitted.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#hasTotalAccountingCurrencyTaxAmount">
