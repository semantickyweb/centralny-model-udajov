    <skos:definition xml:lang="en">Details concerning the Fulfilment of a Despatch Line.</skos:definition>
    <skos:historyNote xml:lang="en">WG approval 16/09/2025</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#Response">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#sub" />
