    <rdfs:range rdf:resource="http://data.europa.eu/a4g/ontology#ConcessionEstimate" />
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/a4g/ontology#core" />
    <skos:prefLabel xml:lang="en">foresees Concession</skos:prefLabel>
