    <rdfs:subClassOf rdf:nodeID="b207541146" />
    <skos:prefLabel xml:lang="en">Temperature Specification</skos:prefLabel>
    <skos:definition xml:lang="en">Description of the temperature requirements during shipment.</skos:definition>
    <skos:historyNote xml:lang="en">WG Approval 21/05/2024</skos:historyNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://data.europa.eu/a4g/ontology#TransportEquipment">
